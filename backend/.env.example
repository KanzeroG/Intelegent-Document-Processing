# Copy this file to `backend/.env` and adjust for your machine.
# `.env` is git-ignored, so each developer sets their own without conflicts.

# Where the LM Studio OpenAI-compatible server is reachable.
#   - Model runs on THIS machine (typical):  http://127.0.0.1:1234/v1/chat/completions
#   - Model runs on another box on your LAN:  http://<that-ip>:1234/v1/chat/completions
LM_STUDIO_URL=http://127.0.0.1:1234/v1/chat/completions

# Secret used to sign session tokens (any random string for local dev).
# AUTH_SECRET=change-me
